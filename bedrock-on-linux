def _emit(tag, m):
    line = f"{tag} {m}"
    if _LOG_SINK:
        try:
            _LOG_SINK(line)
        except Exception:
            pass
    print(line, flush=True)


def info(m): _emit("::", m)
def ok(m):   _emit("OK", m)
def warn(m): _emit("!!", m)
def err(m):  _emit("xx", m)


class BolError(Exception):
    pass


def die(m):
    err(m)

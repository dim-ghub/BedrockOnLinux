class ProxyPass:
    def __init__(self):
        self.proc = None
        self.auth = None        # (url, code)
        self.online = False

    def running(self):
        return self.proc and self.proc.poll() is None

    def start(self, on_auth=None, on_online=None):
        if self.running():
            return
        jar = PROXY_DIR / "ProxyPass.jar"
        java = JRE_DIR / "bin/java"
        log = open(LOGS / "proxypass.log", "w")
        self.proc = subprocess.Popen(
            [str(java), "-jar", str(jar)], cwd=str(PROXY_DIR),
            stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True, bufsize=1)

        def pump():
            for line in self.proc.stdout:
                log.write(line)
                log.flush()
                u = re.search(r"(https?://\S*microsoft\.com/(?:link|devicelogin)\S*)",
                              line, re.I)
                cwd = re.search(r"\bcode[:\s]+([A-Z0-9]{6,9})\b", line, re.I)
                if u or cwd:
                    self.auth = (u.group(1) if u else
                                 "https://www.microsoft.com/link",
                                 cwd.group(1) if cwd else None)
                    if on_auth:
                        on_auth(*self.auth)
                    info(f"Microsoft login → {self.auth[0]}  code {self.auth[1]}")
                if re.search(r"logged in|authenticat|chain|XUID|Saved", line, re.I):
                    if not self.online:
                        self.online = True
                        if on_online:
                            on_online()
                        ok("Microsoft account authenticated")
        threading.Thread(target=pump, daemon=True).start()

    def stop(self):
        if self.running():
            self.proc.terminate()
            try:
                self.proc.wait(5)
            except subprocess.TimeoutExpired:
                self.proc.kill()



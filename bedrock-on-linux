def main():
    p = argparse.ArgumentParser(prog=APP, description=f"{PRETTY} {VERSION}")
    sub = p.add_subparsers(dest="cmd")

    sp = sub.add_parser("setup", help="download & prepare everything")
    sp.add_argument("--game-dir", help="folder with Minecraft.Windows.exe")
    sp.add_argument("--mc", help="Minecraft version tag from the archive "
                                 "(e.g. 1.26.21.1)")
    sp.add_argument("--beta", action="store_true", help="allow beta versions")
    sp.add_argument("--proton", help="GDK-Proton tag (default: latest)")
    sp.add_argument("--proxypass", help="ProxyPass tag (default: auto)")
    sp.add_argument("--force", action="store_true")

    sub.add_parser("play", help="launch the game + ProxyPass")
    lv = sub.add_parser("versions", help="list available Minecraft versions")
    lv.add_argument("--beta", action="store_true")
    cf = sub.add_parser("config", help="show/set settings")
    cf.add_argument("--server", help="destination server  host:port")
    sub.add_parser("doctor", help="check host requirements")
    sub.add_parser("gui", help="graphical launcher")

    a = p.parse_args()
    try:
        if a.cmd == "setup":
            mc = None
            if a.mc:
                vs = list_mc_versions(True)
                mc = next((v for v in vs if v["tag"] == a.mc), None)
                if not mc:
                    die(f"MC version '{a.mc}' not found in archive.")
            do_setup(a.game_dir, mc, a.proton, a.proxypass, a.force)
            ok(f"Done. Launch:  {APP} play")
        elif a.cmd == "play":
            launch()
        elif a.cmd == "versions":
            for v in list_mc_versions(a.beta):
                print(f"  {v['tag']:<14}{'beta' if v['beta'] else 'stable':>7}"
                      f"   {v['size']>>20} MiB")
        elif a.cmd == "config":
            st = load_settings()
            srv = st.setdefault("server",
                                {"host": "geo.hivebedrock.network", "port": 19132})
            if a.server:
                h, _, pt = a.server.partition(":")
                srv.update(host=h, port=int(pt or 19132))
                save_settings(st)
                proxypass_config(srv["host"], srv["port"])
                ok(f"Server = {srv['host']}:{srv['port']}")
            else:
                print(json.dumps(st, indent=2))
        elif a.cmd == "doctor":
            sys.exit(0 if doctor() else 1)
        elif a.cmd == "gui":
            gui()
        else:
            if os.environ.get("DISPLAY") or os.environ.get("WAYLAND_DISPLAY"):
                gui()
            else:
                p.print_help()
    except BolError:
        sys.exit(1)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print()
        sys.exit(130)

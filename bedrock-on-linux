            li.pack(side="left", padx=(0, 14))
        except Exception:
            pass
    ht = tk.Frame(head, bg=BG)
    ht.pack(side="left", anchor="w")
    tk.Label(ht, text="BedrockOnLinux", bg=BG, fg=FG,
             font=("", 19, "bold")).pack(anchor="w")
    tk.Label(ht, text="Minecraft Bedrock — WineGDK in-game login.",
             bg=BG, fg=SUB).pack(anchor="w")

    def card(title):
        outer = tk.Frame(root, bg=BG)
        outer.pack(fill="x", padx=20, pady=7)
        c = tk.Frame(outer, bg=CARD)
        c.pack(fill="x")
        inn = tk.Frame(c, bg=CARD)
        inn.pack(fill="x", padx=16, pady=13)
        tk.Label(inn, text=title, bg=CARD, fg=ACC2,
                 font=("", 10, "bold")).pack(anchor="w", pady=(0, 9))
        body = tk.Frame(inn, bg=CARD)
        body.pack(fill="x")
        return body

    cv = card("\u2460  Minecraft version")
    beta_var = tk.BooleanVar(value=False)
    mc_var = tk.StringVar()
    mc_cb = ttk.Combobox(cv, textvariable=mc_var, width=28, state="readonly")
    mc_cb.grid(row=0, column=0, sticky="w")
    ttk.Checkbutton(cv, text="include betas", variable=beta_var,
                    command=lambda: threading.Thread(
                        target=refresh_mc, daemon=True).start()
                    ).grid(row=0, column=1, padx=12)
    _saved_gd = s.get("game_dir", "")
    try:
        _is_custom = bool(_saved_gd) and Path(_saved_gd).exists() and \
            GAMES.resolve() not in Path(_saved_gd).resolve().parents
    except Exception:
        _is_custom = bool(_saved_gd) and Path(_saved_gd).exists()
    own = tk.StringVar(value=_saved_gd if _is_custom else "")
    ttk.Button(cv, text="\u2026 custom folder",
               command=lambda: own.set(
                   filedialog.askdirectory() or own.get())
               ).grid(row=0, column=2, padx=4)
    mc_cb.bind("<<ComboboxSelected>>", lambda e: own.set(""))

    ce = card("\u2461  Engine \u2014 GDK-Proton built from your WineGDK fork")
    eng_lbl = tk.StringVar(
        value=("custom dir: " + Path(s["proton_dir"]).name)
        if s.get("proton_dir") else
        ("custom URL set" if s.get("proton_url") else
         "build from WineGDK (Wyze3306/WineGDK)"))

    def use_winegdk():
        st = load_settings()
        st["proton_source"] = "winegdk"
        st.setdefault("winegdk_repo", WINEGDK_REPO)
        st.setdefault("winegdk_branch", WINEGDK_BRANCH)
        for k in ("proton_dir", "proton_url", "proton", "proton_tag",
                  "winegdk_built"):
            st.pop(k, None)
        save_settings(st)
        eng_lbl.set("build from WineGDK (Wyze3306/WineGDK)")
        _LOG_SINK("OK Engine = WineGDK fork. Click 'Install / Update' "
                  "(first build is long).")

    def pick_custom_proton():
        d = filedialog.askdirectory()
        if not d:
            return
        st = load_settings()
        if (Path(d) / "proton").exists():
            st["proton_dir"] = d
            for k in ("proton_url", "proton", "proton_tag", "proton_source"):
                st.pop(k, None)
            save_settings(st)
            eng_lbl.set("custom dir: " + Path(d).name)
            _LOG_SINK(f"OK Custom GDK-Proton: {d}")
        else:
            _LOG_SINK("xx No 'proton' executable in that folder")

    ttk.Button(ce, text="\u2699 build from WineGDK",
               command=use_winegdk).grid(row=0, column=0, sticky="w")
    ttk.Button(ce, text="\u2026 custom dir",
               command=pick_custom_proton).grid(row=0, column=1, padx=8)
    tk.Label(ce, textvariable=eng_lbl, bg=CARD, fg="#e0b341"
             ).grid(row=1, column=0, columnspan=3, sticky="w", pady=(8, 0))

    cm = card("\u2462  Microsoft account (sign in happens in-game too)")
    ms_state = tk.StringVar()
    msl = tk.Label(cm, textvariable=ms_state, bg=CARD, font=("", 10, "bold"))
    msl.grid(row=0, column=0, sticky="w")
    ms_code = tk.StringVar(value="")
    tk.Label(cm, textvariable=ms_code, bg=CARD, fg="#e0b341"
             ).grid(row=1, column=0, columnspan=4, sticky="w", pady=(6, 0))

    def set_phase(ph):
        if ph == "in":
            ms_state.set("Connected \u2713")
            msl.configure(fg=ACC2)
            ms_code.set("")
            b_login.grid_remove(); b_link.grid_remove()
            b_code.grid_remove(); b_logout.grid()
        elif ph == "auth":
            ms_state.set("Sign-in required \u2014 open the link, enter the code")
            msl.configure(fg="#e0b341")
            b_login.grid_remove(); b_logout.grid_remove()
            b_link.grid(); b_code.grid()
        else:
            ms_state.set("Not connected")
            msl.configure(fg=SUB)
            ms_code.set("")
            b_link.grid_remove(); b_code.grid_remove()
            b_logout.grid_remove(); b_login.grid()

    def on_auth(u, code):
        root.after(0, lambda: (ms_code.set(f"\u2794  {u}     code : {code}"),
                               set_phase("auth")))

    def on_online():
        root.after(0, lambda: set_phase("in"))

    def open_link():
        if na.auth:
            subprocess.Popen(["xdg-open", na.auth[0]],
                             stdout=subprocess.DEVNULL,
                             stderr=subprocess.DEVNULL)

    def copy_code():
        if na.auth and na.auth[1]:
            root.clipboard_clear()
            root.clipboard_append(na.auth[1])

    def do_logout():
        msa_logout()
        na.stop()
        set_phase("out")

    b_login = ttk.Button(cm, text="Sign in",
                         command=lambda: threading.Thread(
                             target=lambda: na.start(on_auth, on_online),
                             daemon=True).start())
    b_login.grid(row=0, column=1, padx=6)
    b_link = ttk.Button(cm, text="Open link", command=open_link)
    b_link.grid(row=0, column=2, padx=6)
    b_code = ttk.Button(cm, text="Copy code", command=copy_code)
    b_code.grid(row=0, column=3, padx=6)
    b_logout = ttk.Button(cm, text="Sign out", command=do_logout)
    b_logout.grid(row=0, column=1, padx=6)
    set_phase("in" if msa_signed_in() else "out")

    prog = ttk.Progressbar(root, style="Bar.Horizontal.TProgressbar",
                           mode="determinate")
    prog.pack(fill="x", padx=20, pady=(10, 4))
    lw = tk.Frame(root, bg=BG)
    lw.pack(fill="both", expand=True, padx=20, pady=4)
    logbox = tk.Text(lw, height=9, bg="#0b0d11", fg="#79d279", bd=0,
                     relief="flat", insertbackground="#79d279",
                     font=("monospace", 9), highlightthickness=0)
    logbox.pack(fill="both", expand=True)

    def glog(line):
        logbox.insert("end", line + "\n")
        logbox.see("end")
    global _LOG_SINK
    _LOG_SINK = lambda m: root.after(0, glog, m)

    def set_progress(g, t):
        root.after(0, lambda: prog.configure(maximum=t, value=g))

    foot = tk.Frame(root, bg=BG)
    foot.pack(fill="x", padx=20, pady=(8, 18))
    btn_setup = ttk.Button(foot, text="\u27f3  Install / Update",
                           command=lambda: act("setup"))
    btn_setup.pack(side="left")
    ttk.Button(foot, text="\U0001f5ce  Open logs",
               command=lambda: subprocess.Popen(
                   ["xdg-open", str(LOGS)], stdout=subprocess.DEVNULL,
                   stderr=subprocess.DEVNULL)).pack(side="left", padx=10)
    ttk.Button(foot, text="\U0001f6e0  Repair",
               command=lambda: threading.Thread(
                   target=reset_prefix, daemon=True).start()
               ).pack(side="left")
    btn_play = ttk.Button(foot, text="\u25b6    PLAY", style="Accent.TButton",
                          command=lambda: act("play"))
    btn_play.pack(side="right")

    def refresh_mc():
        try:
            versions["mc"] = list_mc_versions(beta_var.get())
            vals = [v["tag"] + ("  \u00b7 beta" if v["beta"] else "")
                    for v in versions["mc"]]

            def ap():
                mc_cb.configure(values=vals)
                if vals and not mc_var.get():
                    cur = (load_settings().get("mc_version") or "")
                    pick = next((v for v in vals if v.split("  ")[0] == cur
                                 or v.split("  ")[0].startswith(cur + ".")),
                                vals[0])
                    mc_var.set(pick)
            root.after(0, ap)
        except Exception as e:
            _LOG_SINK(f"xx versions MC: {e}")

    threading.Thread(target=refresh_mc, daemon=True).start()

    def collect():
        mc = None
        if not own.get() and mc_var.get() and versions["mc"]:
            labels = [v["tag"] + ("  \u00b7 beta" if v["beta"] else "")
                      for v in versions["mc"]]
            mc = versions["mc"][labels.index(mc_var.get())]
        return mc

    def busy(on):
        for b in (btn_setup, btn_play):
            b.configure(state="disabled" if on else "normal")

    def act(kind):
        busy(True)

        def work():
            try:
                mc = collect()
                do_setup(game_dir=own.get() or None, mc_ver=mc,
                         force=(kind == "setup"), progress=set_progress)
                if kind == "play":
                    launch()
                else:
                    _LOG_SINK("OK Ready \u2014 click PLAY")
            except Exception as e:
                _LOG_SINK(f"xx {e}")
            finally:
                root.after(0, lambda: busy(False))
        threading.Thread(target=work, daemon=True).start()

    def on_close():
        na.stop()
        root.destroy()
    root.protocol("WM_DELETE_WINDOW", on_close)
    root.mainloop()


def main():
    p = argparse.ArgumentParser(prog=APP, description=f"{PRETTY} {VERSION}")
    sub = p.add_subparsers(dest="cmd")

    sp = sub.add_parser("setup", help="download & prepare everything")
    sp.add_argument("--game-dir", help="folder with Minecraft.Windows.exe")
    sp.add_argument("--mc", help="Minecraft version tag from the archive "
                                 "(e.g. 1.26.21.1)")
    sp.add_argument("--beta", action="store_true", help="allow beta versions")
    sp.add_argument("--proton", help="(advanced) Weather-OS GDK-Proton tag")
    sp.add_argument("--winegdk", action="store_true",
                    help="(default) build & use the WineGDK fork")
    sp.add_argument("--force", action="store_true")

    sub.add_parser("play", help="launch the game (in-game Microsoft login)")
    lv = sub.add_parser("versions", help="list available Minecraft versions")
    lv.add_argument("--beta", action="store_true")
    cf = sub.add_parser("config", help="show/set settings")
    cf.add_argument("--proton-dir", metavar="PATH",
                    help="use a local GDK-Proton build (a fork with "
                         "WineGDK XUser)")
    cf.add_argument("--proton-url", metavar="URL",
                    help="download a custom GDK-Proton .tar.gz")
    cf.add_argument("--proton-winegdk", nargs="?", const="", metavar="REPO#BRANCH",
                    help="build GDK-Proton from a WineGDK fork (in-game "
                         "login); default: " + WINEGDK_REPO + "#" + WINEGDK_BRANCH)
    cf.add_argument("--proton-auto", action="store_true",
                    help="revert to Weather-OS/GDK-Proton releases")
    sub.add_parser("login", help="link a Microsoft account (in-game login mode)")
    sub.add_parser("doctor", help="check host requirements")
    sub.add_parser("repair", help="reset a broken Wine prefix")
    sub.add_parser("gui", help="graphical launcher")

    a = p.parse_args()
    try:
        if a.cmd == "setup":
            mc = None
            if a.mc:
                vs = list_mc_versions(True)
                mc = next((v for v in vs if v["tag"] == a.mc), None)
                if not mc:
                    die(f"Minecraft version '{a.mc}' not found.")
            if a.winegdk:
                st = load_settings()
                st["proton_source"] = "winegdk"
                st.setdefault("winegdk_repo", WINEGDK_REPO)
                st.setdefault("winegdk_branch", WINEGDK_BRANCH)
                st["native_login"] = True
                save_settings(st)
            do_setup(a.game_dir, mc, a.proton, None, a.force)
            ok(f"Done. Run:  {APP} play")
        elif a.cmd == "play":
            launch()
        elif a.cmd == "versions":
            for v in list_mc_versions(a.beta):
                print(f"  {v['tag']:<14}{'beta' if v['beta'] else 'stable':>7}"
                      f"   {v['size']>>20} MiB")
        elif a.cmd == "config":
            st = load_settings()
            touched = False
            if a.proton_dir:
                pth = str(Path(a.proton_dir).expanduser())
                if not (Path(pth) / "proton").exists():
                    die(f"No 'proton' executable in {pth}")
                st["proton_dir"] = pth
                st.pop("proton_url", None)
                st.pop("proton", None)
                st.pop("proton_tag", None)
                save_settings(st)
                ok(f"Custom GDK-Proton dir = {pth}")
                touched = True
            if a.proton_url:
                st["proton_url"] = a.proton_url
                st.pop("proton_dir", None)
                st.pop("proton", None)
                st.pop("proton_tag", None)
                save_settings(st)
                ok("Custom GDK-Proton URL set — runs on next setup/play.")
                touched = True
            if a.proton_winegdk is not None:
                repo, _, branch = a.proton_winegdk.partition("#")
                st["proton_source"] = "winegdk"
                st["winegdk_repo"] = repo or WINEGDK_REPO
                st["winegdk_branch"] = branch or WINEGDK_BRANCH
                st["native_login"] = True
                for k in ("proton_dir", "proton_url", "proton", "proton_tag",
                          "winegdk_built"):
                    st.pop(k, None)
                save_settings(st)
                ok(f"GDK-Proton = build from {st['winegdk_repo']}"
                   f"#{st['winegdk_branch']} (native login on). Run "
                   "'Install / Update'.")
                touched = True
            if a.proton_auto:
                for k in ("proton_dir", "proton_url", "proton", "proton_tag",
                          "proton_source", "winegdk_repo", "winegdk_branch",
                          "winegdk_built"):
                    st.pop(k, None)
                save_settings(st)
                ok("GDK-Proton = auto (Weather-OS releases)")
                touched = True
            if not touched:
                print(json.dumps(st, indent=2))
        elif a.cmd == "login":
            na = NativeAuth()
            if na.signed_in():
                ok("A Microsoft account is already linked.")
            else:
                na._flow(None, None)
                if not na.signed_in():
                    sys.exit(1)
        elif a.cmd == "doctor":
            sys.exit(0 if doctor() else 1)
        elif a.cmd == "repair":
            reset_prefix()
        elif a.cmd == "gui":
            gui()
        else:
            if os.environ.get("DISPLAY") or os.environ.get("WAYLAND_DISPLAY"):
                gui()
            else:
                p.print_help()
    except BolError:
        sys.exit(1)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print()
        sys.exit(130)

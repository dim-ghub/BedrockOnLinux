def doctor():
    info(f"{PRETTY} {VERSION} — host check")
    hint = next((h for pm, h in (
        ("apt-get", "sudo apt install {}"), ("dnf", "sudo dnf install {}"),
        ("pacman", "sudo pacman -S {}"), ("zypper", "sudo zypper in {}"))
        if shutil.which(pm)), "install: {}")
    miss = []
    print(f"  python3 : {sys.version.split()[0]}")
    for tool, pkg in (("bwrap", "bubblewrap"), ("tar", "tar"),
                      ("curl", "curl"), ("unzstd", "zstd")):
        have = shutil.which(tool)
        print(f"  {tool:8}: {'found' if have else 'MISSING'}")
        if not have and not (tool == "curl" and shutil.which("wget")):
            miss.append(pkg)
    try:
        import tkinter  # noqa
        print("  tkinter : found")
    except Exception:
        print("  tkinter : MISSING")
        miss.append("python3-tk")
    if miss:
        warn("Install: " + hint.format(" ".join(sorted(set(miss)))))
        return False
    ok("Host ready.")
    return True



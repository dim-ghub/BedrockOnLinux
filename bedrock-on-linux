#!/usr/bin/env python3
# -*- coding: utf-8 -*-
# BedrockOnLinux — launcher entry point.
#
# The implementation lives in the `bol` package. This thin wrapper makes that
# package importable whether BedrockOnLinux runs from a dev checkout / portable
# folder (bol/ sits next to this file) or from a packaged install (bol/ under
# <prefix>/lib/bedrock-on-linux), then hands off to bol.cli.main.
# SPDX-License-Identifier: MIT
import os
import sys

_here = os.path.dirname(os.path.realpath(__file__))
for _cand in (_here,                                   # dev / portable folder
              os.path.join(os.path.dirname(_here), "lib", "bedrock-on-linux")):
    if os.path.isdir(os.path.join(_cand, "bol")):
        sys.path.insert(0, _cand)
        break

try:
    from bol.cli import main
except ModuleNotFoundError:
    sys.exit("BedrockOnLinux: the 'bol' package is missing — reinstall the app "
             "(https://github.com/Wyze3306/BedrockOnLinux).")

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print()
        sys.exit(130)

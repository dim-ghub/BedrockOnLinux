    prog.pack(fill="x", padx=20, pady=(10, 4))
    lw = tk.Frame(root, bg=BG)
    lw.pack(fill="both", expand=True, padx=20, pady=4)
    logbox = tk.Text(lw, height=8, bg="#0b0d11", fg="#79d279", bd=0,
                     relief="flat", insertbackground="#79d279",
                     font=("monospace", 9), highlightthickness=0)
    logbox.pack(fill="both", expand=True)

    def glog(line):
        logbox.insert("end", line + "\n")
        logbox.see("end")
    global _LOG_SINK
    _LOG_SINK = lambda m: root.after(0, glog, m)

    def set_progress(g, t):
        root.after(0, lambda: prog.configure(maximum=t, value=g))

    foot = tk.Frame(root, bg=BG)
    foot.pack(fill="x", padx=20, pady=(8, 18))
    btn_setup = ttk.Button(foot, text="⟳  Install / Update",
                           command=lambda: act("setup"))
    btn_setup.pack(side="left")
    ttk.Button(foot, text="🗎  Open logs",
               command=lambda: subprocess.Popen(
                   ["xdg-open", str(LOGS)], stdout=subprocess.DEVNULL,
                   stderr=subprocess.DEVNULL)).pack(side="left", padx=10)

    def show_pp_log():
        win = tk.Toplevel(root)
        win.title("ProxyPass logs — multiplayer relay (live)")
        win.configure(bg=BG)
        win.geometry("900x520")
        txt = tk.Text(win, bg="#0c0c0c", fg="#d6d6d6", insertbackground="#d6d6d6",
                      font=("monospace", 9), wrap="none", borderwidth=0)
        sb = ttk.Scrollbar(win, command=txt.yview)
        txt.configure(yscrollcommand=sb.set)
        sb.pack(side="right", fill="y")
        txt.pack(fill="both", expand=True, padx=6, pady=6)
        lf = PROXY_DIR / "logs" / "latest.log"
        st = {"sz": 0, "alive": True}

        def tick():
            if not st["alive"] or not win.winfo_exists():
                return
            try:
                if lf.exists():
                    sz = lf.stat().st_size
                    if sz < st["sz"]:           # rotated → reload
                        st["sz"] = 0
                        txt.delete("1.0", "end")
                    if sz > st["sz"]:
                        with open(lf, "r", errors="ignore") as fh:
                            fh.seek(st["sz"])
                            chunk = fh.read()
                        st["sz"] = sz
                        at_end = txt.yview()[1] > 0.999
                        txt.insert("end", chunk)
                        if at_end:
                            txt.see("end")
                else:
                    if not txt.get("1.0", "1.5"):
                        txt.insert("end", "(ProxyPass not started yet — "
                                   "click PLAY)\n")
            except Exception as e:
                txt.insert("end", f"\n[lecture log: {e}]\n")
            win.after(700, tick)

        win.protocol("WM_DELETE_WINDOW",
                     lambda: (st.update(alive=False), win.destroy()))
        tick()

    ttk.Button(foot, text="🔌  ProxyPass logs",
               command=show_pp_log).pack(side="left", padx=(0, 10))
    ttk.Button(foot, text="🛠  Repair",
               command=lambda: threading.Thread(
                   target=reset_prefix, daemon=True).start()
               ).pack(side="left")
    btn_play = ttk.Button(foot, text="▶    PLAY", style="Accent.TButton",
                          command=lambda: act("play"))

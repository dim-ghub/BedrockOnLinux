# --------------------------------------------------------------------------- #
#  logging helpers (route to GUI when present)
# --------------------------------------------------------------------------- #
def _emit(tag, m):
    line = f"{tag} {m}"
    if _LOG_SINK:
        try:
            _LOG_SINK(line)
        except Exception:
            pass
    print(line, flush=True)


def info(m): _emit("::", m)
def ok(m):   _emit("OK", m)
def warn(m): _emit("!!", m)
def err(m):  _emit("xx", m)


class BolError(Exception):
    pass


def die(m):
    err(m)
    raise BolError(m)


def run(cmd, **kw):
    kw.setdefault("check", True)
    return subprocess.run(cmd, **kw)


def mkdirs():
    for d in (DATA, PROTON_DIR, UMU_DIR, JRE_DIR, PROXY_DIR, CACHE, LOGS, GAMES):

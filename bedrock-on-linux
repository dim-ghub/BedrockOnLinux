    ms_code = tk.StringVar(value="")
    tk.Label(cm, textvariable=ms_code, bg=CARD, fg="#e0b341"
             ).grid(row=1, column=0, columnspan=4, sticky="w", pady=(6, 0))

    native_var = tk.BooleanVar(value=bool(s.get("native_login")))

    def cur_auth():
        return na if native_var.get() else pp

    def toggle_native():
        st = load_settings()
        st["native_login"] = bool(native_var.get())
        save_settings(st)
        (pp if native_var.get() else na).stop()
        set_phase("in" if account_signed_in(native_var.get()) else "out")

    ttk.Checkbutton(
        cm, text="In-game login — no ProxyPass (experimental, needs a "
        "GDK-Proton with WineGDK XUser)", variable=native_var,
        command=toggle_native).grid(row=2, column=0, columnspan=4,
                                    sticky="w", pady=(8, 0))

    # phase: "in" (signed in) / "auth" (enter code) / "out" (signed out)
    def set_phase(ph):
        if ph == "in":
            ms_state.set("Connected ✓")
            msl.configure(fg=ACC2)
            ms_code.set("")
            b_login.grid_remove()
            b_link.grid_remove()
            b_code.grid_remove()
            b_logout.grid()
        elif ph == "auth":
            ms_state.set("Sign-in required — open the link and enter the code")
            msl.configure(fg="#e0b341")
            b_login.grid_remove()
            b_logout.grid_remove()
            b_link.grid()
            b_code.grid()
        else:
            ms_state.set("Not connected")
            msl.configure(fg=SUB)
            ms_code.set("")
            b_link.grid_remove()
            b_code.grid_remove()
            b_logout.grid_remove()
            b_login.grid()


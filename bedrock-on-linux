def custom_proton():
    """A user-supplied GDK-Proton (e.g. a fork built with WineGDK XUser).
    When set, our combase/ntdll offsets may not match — patch non-strict."""
    s = load_settings()
    return bool(s.get("proton_dir") or s.get("proton_url"))



def _pkill(pattern):
    """Best-effort kill of processes whose cmdline matches `pattern`."""
    if shutil.which("pkill"):
        subprocess.run(["pkill", "-9", "-f", pattern],
                        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return
    for pid in os.listdir("/proc"):
        if not pid.isdigit():
            continue
        try:
            cl = Path(f"/proc/{pid}/cmdline").read_bytes().replace(b"\0", b" ")
            if pattern.encode() in cl:
                os.kill(int(pid), 9)
        except Exception:
            pass


class ProxyPass:
    """The multiplayer relay. Stale instances are killed before start so
    the 0.0.0.0:19132 bind never fails."""

    def __init__(self):
        self.proc = None
        self.auth = None        # (url, code)
        self.online = False
        self.dest = None        # (host, port) the running relay points at
        self.client_seen = False
        self.ready = False

    def running(self):
        return self.proc and self.proc.poll() is None

    def start(self, on_auth=None, on_online=None, dest=None):
        if self.running():
            return
        _pkill("ProxyPass.jar")          # free 19132 from any stale instance
        time.sleep(1)
        jar = PROXY_DIR / "ProxyPass.jar"
        java = JRE_DIR / "bin/java"
        log = open(LOGS / "proxypass.log", "w")
        self.auth = None
        self.online = False
        self.client_seen = False
        self.ready = False
        self.dest = dest
        if dest:
            info(f"Relay → {dest[0]}:{dest[1]} (local :19132)")
        self.proc = subprocess.Popen(
            [str(java), "-jar", str(jar)], cwd=str(PROXY_DIR),
            stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True, bufsize=1)

        def pump():
            for line in self.proc.stdout:
                log.write(line)
                log.flush()
                msg = line.strip().split("]: ")[-1].split(" - ")[-1]
                if re.search(r"Address already in use|Failed to bind", line, re.I):
                    err("Port 19132 in use — close other instances.")
                u = re.search(r"(https?://\S*microsoft\.com/"
                              r"(?:link|devicelogin)\S*)", line, re.I)
                cd = re.search(r"\bcode[:\s]+([A-Z0-9]{6,9})\b", line, re.I)
                if u or cd:
                    self.auth = (u.group(1) if u else
                                 "https://www.microsoft.com/link",
                                 cd.group(1) if cd else None)
                    if on_auth:
                        on_auth(*self.auth)
                    info(f"Microsoft sign-in → {self.auth[0]} "
                         f"code {self.auth[1]}")
                if not self.online and re.search(
                        r"logged in|authenticat|chain|XUID|Saved", line, re.I):
                    self.online = True
                    if on_online:
                        on_online()
                    ok("Microsoft account connected")
                if re.search(r"Resolving server address|Loading server",
                             line, re.I):
                    info(msg)
                if not self.ready and re.search(
                        r"(?:Bedrock|NetherNet) server started on",
                        line, re.I):
                    self.ready = True
                    threading.Thread(target=self._watchdog,
                                     daemon=True).start()
                    ok("Relay ready — in game: Play ▸ Worlds ▸ "
                       "'ProxyPass'.")
                if not self.client_seen and re.search(
                        r"Dispatching New Connection|Initializing proxy "
                        r"session|LoginPacket|Player .*connect|"
                        r"received .* from /", line, re.I):
                    self.client_seen = True
                    ok("Client connecting …")
                if re.search(r"outdated client|outdated server|"
                             r"ProtocolException", line, re.I):
                    err("ProxyPass ↔ Minecraft version mismatch.")
                elif re.search(r"No route to host|UnknownHost|downstream "
                               r"server.*(?:refused|timed? ?out)", line, re.I):
                    err(f"Server {self.dest} unreachable — {msg}")
                elif re.search(r"disconnect|kicked|Connection "
                               r"(?:reset|closed|refused)", line, re.I):
                    warn(msg)
                elif re.search(r"Exception|ERROR|SEVERE", line) and \
                        "StaticLoggerBinder" not in line:
                    warn(msg[:200])
        threading.Thread(target=pump, daemon=True).start()

    def _watchdog(self):
        time.sleep(50)
        if self.client_seen or not self.running():
            return
        warn("No client after 50 s — in game: Play ▸ Worlds ▸ "
             "'ProxyPass'. Otherwise open 'ProxyPass logs'.")

    def stop(self):
        if self.running():
            self.proc.terminate()
            try:
                self.proc.wait(5)
            except subprocess.TimeoutExpired:
                self.proc.kill()
        _pkill("ProxyPass.jar")



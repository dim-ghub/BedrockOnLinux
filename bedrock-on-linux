def diagnose():
    """Scan the game + ProxyPass logs and surface a human cause, if any."""
    blobs = []
    for name in ("proton.log", "steam-0.log", "minecraft.log", "proxypass.log"):
        p = LOGS / name
        if p.exists():
            try:
                blobs.append(p.read_text(errors="ignore")[-200000:])
            except Exception:
                pass
    text = "\n".join(blobs)
    hits = []
    for pat, msg in _DIAG_RULES:
        if re.search(pat, text, re.I):
            hits.append(msg)
    if hits:
        warn("Cause probable du crash :")
        for h in dict.fromkeys(hits):
            warn("  • " + h)
    else:
        info("Aucune cause connue détectée. Détail : " + str(LOGS))
    info(f"Logs complets : {LOGS}")
    return hits


def launch(pp: "ProxyPass" = None):
    s = load_settings()
    gd = s.get("game_dir")
    if not gd or not Path(gd, "Minecraft.Windows.exe").exists():
        die("Not set up — pick a Minecraft version first.")
    if not proton_path():
        die("GDK-Proton missing — run setup.")
    patch_proton(proton_path())
    proxypass_config(s["server"]["host"], s["server"]["port"])
    if pp is None:
        pp = ProxyPass()
    if not pp.running():
        info("Starting ProxyPass (multiplayer relay) …")
        pp.start()
    kill_wine()                              # clear any hung/locking wine
    env = proton_env()
    env["PROTON_LOG"] = "1"                   # so crashes are diagnosable
    env["PROTON_LOG_DIR"] = str(LOGS)
    disp = os.environ.get("DISPLAY")
    if disp:
        env["DISPLAY"] = disp
        xa = os.environ.get("XAUTHORITY")
        for cand in (xa, str(HOME / ".Xauthority"),
                     f"/run/user/{os.getuid()}/.mutter-Xwaylandauth.0"):
            if cand and Path(cand).exists():
                env["XAUTHORITY"] = cand
                break
        # The pressure-vessel container often can't use the host X cookie →
        # "no driver could be loaded". Allow the local user explicitly.
        if shutil.which("xhost"):
            user = os.environ.get("USER") or os.environ.get("LOGNAME") or ""
            granted = False
            for arg in (f"+SI:localuser:{user}", "+local:"):
                try:
                    r = subprocess.run(["xhost", arg], timeout=5,
                                       stdout=subprocess.DEVNULL,
                                       stderr=subprocess.DEVNULL)
                    granted = granted or r.returncode == 0
                except Exception:
                    pass
            info(f"X: accès local accordé via xhost (DISPLAY={disp}, "
                 f"XAUTHORITY={env.get('XAUTHORITY','?')})" if granted
                 else "X: xhost a échoué — l'affichage risque d'échouer.")
        else:
            warn("xhost absent (installe x11-xserver-utils) — l'affichage "
                 "dans le conteneur risque d'échouer.")
    elif os.environ.get("WAYLAND_DISPLAY"):
        warn("Session Wayland sans DISPLAY X — installe XWayland, "
             "ou lance depuis une session X11 (Wine-Wayland est instable).")
    exe = str(CONTENT / "Minecraft.Windows.exe")
    info("Launching Minecraft … (in game: Play ▸ Friends ▸ join the LAN game)")
    glog = open(LOGS / "minecraft.log", "w")
    rc = None
    try:
        rc = subprocess.run([sys.executable, str(ensure_umu()), exe], env=env,
                            cwd=str(CONTENT), stdout=glog,
                            stderr=subprocess.STDOUT).returncode
    finally:
        patch_options()
        for pat in ("steam-0.log",):           # PROTON_LOG writes here
            src = LOGS / pat
            if src.exists():
                src.replace(LOGS / "proton.log")
        ok(f"Game closed (exit {rc}).")
        diagnose()


def doctor():
    info(f"{PRETTY} {VERSION} — host check")
    hint = next((h for pm, h in (
        ("apt-get", "sudo apt install {}"), ("dnf", "sudo dnf install {}"),
        ("pacman", "sudo pacman -S {}"), ("zypper", "sudo zypper in {}"))
        if shutil.which(pm)), "install: {}")
    miss = []
    print(f"  python3 : {sys.version.split()[0]}")
    for tool, pkg in (("bwrap", "bubblewrap"), ("tar", "tar"),
                      ("curl", "curl"), ("unzstd", "zstd")):
        have = shutil.which(tool)
        print(f"  {tool:8}: {'found' if have else 'MISSING'}")
        if not have and not (tool == "curl" and shutil.which("wget")):
            miss.append(pkg)
    try:
        import tkinter  # noqa
        print("  tkinter : found")
    except Exception:
        print("  tkinter : MISSING")
        miss.append("python3-tk")
    if miss:
        warn("Install: " + hint.format(" ".join(sorted(set(miss)))))
        return False
    ok("Host ready.")
    return True



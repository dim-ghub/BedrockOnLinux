    def on_auth(url, code):
        ms_state.set("Connexion requise →")
        ms_code.set(f"{url}  |  code: {code}")

    def on_online():
        ms_state.set("Connecté ✓")
        ms_code.set("")

    ttk.Button(f4, text="Se connecter à Microsoft",
               command=lambda: threading.Thread(
                   target=lambda: (ensure_jre(),
                                   pp.start(on_auth, on_online)),
                   daemon=True).start()).grid(row=1, column=0, columnspan=2, pady=4)

    # --- progress + log -----------------------------------------------------
    prog = ttk.Progressbar(root, mode="determinate")
    prog.pack(fill="x", **pad)
    logbox = tk.Text(root, height=9, bg="#10131a", fg="#7fd17f",
                     insertbackground="#7fd17f", relief="flat")
    logbox.pack(fill="both", expand=True, **pad)

    def glog(line):
        logbox.insert("end", line + "\n")
        logbox.see("end")
    global _LOG_SINK
    _LOG_SINK = lambda m: root.after(0, glog, m)

    def set_progress(got, total):
        root.after(0, lambda: (prog.configure(maximum=total, value=got)))

    # --- populate version lists in background -------------------------------
    def refresh_mc():
        try:
            versions["mc"] = list_mc_versions(beta_var.get())
            vals = [f"{v['tag']}{'  (bêta)' if v['beta'] else ''}"
                    for v in versions["mc"]]
            root.after(0, lambda: mc_cb.configure(values=vals))
            if vals and not mc_var.get():
                root.after(0, lambda: mc_var.set(vals[0]))
        except Exception as e:
            _LOG_SINK(f"xx versions MC: {e}")

    def refresh_engine():
        versions["proton"] = list_proton_tags() or ["latest"]
        versions["pp"] = ["auto (selon version MC)"] + list_proxypass_tags()
        pcb = f2.children["proton"]
        ppcb = f2.children["pp"]

        def apply():
            pcb.configure(values=versions["proton"])
            proton_var.set(versions["proton"][0])
            ppcb.configure(values=versions["pp"])
            pp_var.set("auto (selon version MC)")
        root.after(0, apply)
    threading.Thread(target=refresh_mc, daemon=True).start()
    threading.Thread(target=refresh_engine, daemon=True).start()

    # --- actions ------------------------------------------------------------
    def collect():
        st = load_settings()
        st["server"] = {"host": host_var.get().strip(),
                        "port": int(port_var.get() or 19132)}
        save_settings(st)
        mc_ver = None
        if own.get():
            use_game_dir(own.get())
        elif mc_var.get() and versions["mc"]:
            idx = [f"{v['tag']}{'  (bêta)' if v['beta'] else ''}"
                   for v in versions["mc"]].index(mc_var.get())
            mc_ver = versions["mc"][idx]
        pt = None if proton_var.get() in ("", "latest") else proton_var.get()
        ppt = None if pp_var.get().startswith("auto") else pp_var.get()
        return mc_ver, pt, ppt

    def busy(on):
        for b in (btn_setup, btn_play):
            b.configure(state="disabled" if on else "normal")

    def do_setup():
        busy(True)

        def w():
            try:
                mc, pt, ppt = collect()
                do_setup_inner(mc, pt, ppt)
                _LOG_SINK("OK Prêt — clique JOUER")
            except Exception as e:
                _LOG_SINK(f"xx {e}")
            finally:
                root.after(0, lambda: busy(False))
        threading.Thread(target=w, daemon=True).start()

    def do_setup_inner(mc, pt, ppt):
        do_setup(game_dir=own.get() or None, mc_ver=mc, proton_tag=pt,
                 pp_tag=ppt, progress=set_progress)

    def do_play():
        busy(True)

        def w():
            try:
                mc, pt, ppt = collect()
                do_setup_inner(mc, pt, ppt)
                launch(pp)
            except Exception as e:
                _LOG_SINK(f"xx {e}")
            finally:
                root.after(0, lambda: busy(False))
        threading.Thread(target=w, daemon=True).start()

    bar = tk.Frame(root)
    bar.pack(pady=8)
    btn_setup = ttk.Button(bar, text="Installer / Mettre à jour", command=do_setup)
    btn_setup.grid(row=0, column=0, padx=8)
    btn_play = tk.Button(bar, text="▶  JOUER", command=do_play, bg="#2e7d32",
                         fg="white", font=("", 12, "bold"), relief="flat",
                         padx=20, pady=6)
    btn_play.grid(row=0, column=1, padx=8)

    def on_close():
        pp.stop()
        root.destroy()
    root.protocol("WM_DELETE_WINDOW", on_close)
    root.mainloop()



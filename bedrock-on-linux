def ensure_umu(force=False):
    binp = UMU_DIR / "umu-run"
    if binp.exists() and not force:
        return binp
    rel = gh_latest(UMU_REPO)
    url, fname, _ = asset_url(rel, lambda n: n.endswith("zipapp.tar") or n == "umu-run")
    if not url:
        url, fname, _ = asset_url(rel, lambda n: n.endswith((".tar", ".tar.gz")))
    if not url:
        die("No umu-launcher asset.")
    pkg = CACHE / fname
    info("Downloading umu-launcher …")
    download(url, pkg, "umu-launcher")
    if fname == "umu-run":
        shutil.copy2(pkg, binp)
    else:
        with tarfile.open(pkg) as t:
            t.extractall(UMU_DIR)
        found = next((p for p in UMU_DIR.rglob("umu-run")), None)
        if not found:
            die("umu-run not in package.")
        if found != binp:
            shutil.copy2(found, binp)
    os.chmod(binp, 0o755)
    ok("umu-launcher ready")
    return binp


def ensure_jre(force=False):
    j = JRE_DIR / "bin/java"
    if j.exists() and not force:
        return j
    info("Downloading bundled Java 25 …")
    tgz = CACHE / "temurin-jre25.tar.gz"
    download(TEMURIN_JRE25, tgz, "Java 25")
    if JRE_DIR.exists():
        shutil.rmtree(JRE_DIR)
    JRE_DIR.mkdir(parents=True)
    with tarfile.open(tgz) as t:
        top = t.getmembers()[0].name.split("/")[0]
        t.extractall(JRE_DIR)
    ext = JRE_DIR / top
    for item in ext.iterdir():
        shutil.move(str(item), str(JRE_DIR / item.name))
    ext.rmdir()
    os.chmod(j, 0o755)
    ok("Java 25 ready")
    return j



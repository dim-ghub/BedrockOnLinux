_DIAG_RULES = [
    (r"Unimplemented function combase\.dll\.RoOriginateError|"
     r"RoOriginateErrorW",
     "combase patch missing — re-run 'Install / Update'."),
    (r"NtQueryWnfStateData|Unimplemented function .*aborting",
     "ntdll patch missing — re-run 'Install / Update'."),
    (r"vkGetPhysicalDeviceSurfaceFormatsKHR|Can't open display|x11drv: Can't",
     "Display unavailable (no X/Wayland server)."),
    (r"VK_ERROR_DEVICE_LOST|device removed|DXGI_ERROR|vkd3d.*fatal|"
     r"VK_ERROR_OUT_OF_DEVICE_MEMORY",
     "GPU/Vulkan crash — update the driver or lower graphics."),
    (r"Cannot allocate memory|OutOfMemory|std::bad_alloc",
     "Out of memory (RAM/VRAM)."),
    (r"Address already in use|Failed to bind RakNet",
     "Port 19132 in use — close other ProxyPass instances."),
    (r"outdated client|outdated server|ProtocolException",
     "ProxyPass ↔ Minecraft version mismatch — change the ProxyPass "
     "build (master-… follows the recent protocol)."),
    (r"Authentication failed|invalid_grant|login.*failed",
     "Microsoft sign-in failed — click 'Sign in' again."),
    (r"nodrv_CreateWindow|no driver could be loaded|"
     r"explorer process failed to start",
     "Wine prefix broken — click 'Repair' then relaunch."),
]


def diagnose():
    """Scan game + relay logs and surface a likely cause."""
    blobs = []
    paths = [LOGS / n for n in ("proton.log", "minecraft.log",
                                "proxypass.log")]
    paths.append(PROXY_DIR / "logs" / "latest.log")
    for p in paths:
        if p.exists():
            try:
                blobs.append(p.read_text(errors="ignore")[-200000:])
            except Exception:
                pass
    text = "\n".join(blobs)
    hits = [msg for pat, msg in _DIAG_RULES if re.search(pat, text, re.I)]
    relay_up = re.search(r"(?:Bedrock|NetherNet) server started on", text)
    joined = re.search(r"Dispatching New Connection|Initializing proxy "
                       r"session|LoginPacket|Player .*connect|"
                       r"received .* from /", text, re.I)
    if relay_up and not joined:
        hits.append("Relay OK but no client connected — in game: "
                    "Play ▸ Worlds ▸ 'ProxyPass'.")
    elif not relay_up:
        hits.append("The relay did not start — see 'ProxyPass logs' "
                    "(often: reconnect the Microsoft account).")
    if hits:
        warn("Likely cause:")
        for h in dict.fromkeys(hits):
            warn("  • " + h)
    else:
        info(f"No known cause. Logs: {LOGS}")
    return hits


def launch(pp: "ProxyPass" = None):
    s = load_settings()
    gd = s.get("game_dir")
    if not gd or not Path(gd, "Minecraft.Windows.exe").exists():
        die("No game — choose a Minecraft version first.")
    if not proton_path():
        die("GDK-Proton missing — re-run setup.")
    patch_proton(proton_path())

    native = bool(s.get("native_login"))
    if native:
        tok = msa_load().get("refresh_token")
        if not tok:
            die("In-game login is enabled but no Microsoft account is "
                "linked — click 'Sign in' first.")
        info("In-game login mode — ProxyPass disabled.")
        try:
            fresh = msa_refresh(tok)
        except Exception as e:
            fresh = None
            warn(f"Token refresh skipped ({e}) — using cached token.")
        if fresh:
            msa_save({"refresh_token": fresh["refresh_token"],
                      "obtained": int(time.time())})
            tok = fresh["refresh_token"]
        wine_reg_set_refresh_token(tok)
        warn("Needs a GDK-Proton with WineGDK XUser (PR #33). Sign-in and "
             "server join happen inside Minecraft (no LAN relay).")
    else:
        # Warn only if a version-locked pre/<ver> ProxyPass is older than MC.
        mc_ver = mc_version_str(Path(gd))
        pp_tag = s.get("proxypass_tag", "") or ""
        m = re.match(r"pre/(\d+\.\d+\.\d+)-\d+$", pp_tag)
        if mc_ver and m and _vt(mc_ver) > _vt(m.group(1)):
            warn(f"ProxyPass {pp_tag} only supports MC {m.group(1)} (you are "
                 f"on {mc_ver}) — choose a 'master-…' build.")
        dest = (s["server"]["host"], int(s["server"]["port"]))
        proxypass_config(*dest)
        if pp is None:
            pp = ProxyPass()
        # The relay reads config.yml only at startup → restart it if the
        # chosen server changed.
        if pp.running() and pp.dest != dest:
            info(f"Server changed → restarting the relay ({dest})")
            pp.stop()
            time.sleep(1)
        if not pp.running():
            info("Starting the relay …")
            pp.start(dest=dest)
        else:
            info(f"Relay already active → {dest[0]}:{dest[1]}")
    kill_wine()
    exe = str(CONTENT / "Minecraft.Windows.exe")
    cmd, env = proton_umu_cmd(exe)
    env["PROTON_LOG"] = "1"
    env["PROTON_LOG_DIR"] = str(LOGS)
    disp = os.environ.get("DISPLAY")
    if disp:
        env["DISPLAY"] = disp
        for cand in (os.environ.get("XAUTHORITY"), str(HOME / ".Xauthority"),
                     f"/run/user/{os.getuid()}/.mutter-Xwaylandauth.0"):
            if cand and Path(cand).exists():
                env["XAUTHORITY"] = cand
                break
        if shutil.which("xhost"):
            user = os.environ.get("USER") or os.environ.get("LOGNAME") or ""
            for arg in (f"+SI:localuser:{user}", "+local:"):
                try:
                    subprocess.run(["xhost", arg], timeout=5,
                                   stdout=subprocess.DEVNULL,
                                   stderr=subprocess.DEVNULL)
                except Exception:
                    pass
    elif os.environ.get("WAYLAND_DISPLAY"):
        warn("Wayland session without X DISPLAY — install XWayland.")
    if native:
        info("Launching Minecraft … Sign in with Microsoft, then add and "
             "join your server in-game (Play ▸ Servers).")
    else:
        info("Launching Minecraft … In game: Play ▸ Worlds ▸ the "
             "LAN world 'ProxyPass'.")
    glog = open(LOGS / "minecraft.log", "w")
    rc = None
    try:
        rc = subprocess.run(cmd, env=env, cwd=str(CONTENT), stdout=glog,
                            stderr=subprocess.STDOUT).returncode
    finally:
        patch_options()
        src = LOGS / "steam-0.log"             # PROTON_LOG output
        if src.exists():
            src.replace(LOGS / "proton.log")
        ok(f"Game closed (exit {rc}).")
        diagnose()



        root.after(0, lambda: (ms_code.set(f"➜  {u}     code : {code}"),
                               set_phase("auth")))

    def on_online():
        root.after(0, lambda: set_phase("in"))

    def open_link():
        a = cur_auth()
        if a.auth:
            subprocess.Popen(["xdg-open", a.auth[0]],
                             stdout=subprocess.DEVNULL,
                             stderr=subprocess.DEVNULL)

    def copy_code():
        a = cur_auth()
        if a.auth and a.auth[1]:
            root.clipboard_clear()
            root.clipboard_append(a.auth[1])

    def do_logout():
        if native_var.get():
            msa_logout()
            na.stop()
        else:
            for n in ("auth.json", "data"):
                p = PROXY_DIR / n
                try:
                    shutil.rmtree(p) if p.is_dir() \
                        else p.unlink(missing_ok=True)
                except Exception:
                    pass
            pp.stop()
        set_phase("out")

    def _do_login():
        a = cur_auth()
        if a is pp:
            ensure_jre()
        a.start(on_auth, on_online)

    b_login = ttk.Button(cm, text="Sign in",

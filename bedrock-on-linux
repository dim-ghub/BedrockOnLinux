def _pkill(pattern):
    """Best-effort kill of processes whose cmdline matches `pattern`."""
    if shutil.which("pkill"):
        subprocess.run(["pkill", "-9", "-f", pattern],
                        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return
    for pid in os.listdir("/proc"):
        if not pid.isdigit():
            continue
        try:
            cl = Path(f"/proc/{pid}/cmdline").read_bytes().replace(b"\0", b" ")
            if pattern.encode() in cl:
                os.kill(int(pid), 9)
        except Exception:
            pass


class ProxyPass:
    """Single global instance. Stale ProxyPass processes (from a previous
    run / repeated clicks) are killed first, otherwise it fails to bind
    0.0.0.0:19132 (BindException) and multiplayer silently breaks."""

    def __init__(self):
        self.proc = None
        self.auth = None        # (url, code)
        self.online = False

    def running(self):
        return self.proc and self.proc.poll() is None

    def start(self, on_auth=None, on_online=None):
        if self.running():
            return
        _pkill("ProxyPass.jar")          # free 19132 from any stale instance
        time.sleep(1)
        jar = PROXY_DIR / "ProxyPass.jar"
        java = JRE_DIR / "bin/java"
        log = open(LOGS / "proxypass.log", "w")
        self.auth = None
        self.online = False
        self.proc = subprocess.Popen(
            [str(java), "-jar", str(jar)], cwd=str(PROXY_DIR),
            stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True, bufsize=1)

        def pump():
            for line in self.proc.stdout:
                log.write(line)
                log.flush()
                if re.search(r"Address already in use|Failed to bind", line, re.I):
                    err("ProxyPass: port 19132 occupé — relais multijoueur KO. "
                        "Ferme les autres instances et relance.")
                u = re.search(r"(https?://\S*microsoft\.com/(?:link|devicelogin)\S*)",
                              line, re.I)
                cd = re.search(r"\bcode[:\s]+([A-Z0-9]{6,9})\b", line, re.I)
                if u or cd:
                    self.auth = (u.group(1) if u else
                                 "https://www.microsoft.com/link",
                                 cd.group(1) if cd else None)
                    if on_auth:
                        on_auth(*self.auth)
                    info(f"Microsoft login → {self.auth[0]}  code {self.auth[1]}")
                if re.search(r"logged in|authenticat|chain|XUID|Saved", line, re.I):
                    if not self.online:
                        self.online = True
                        if on_online:
                            on_online()
                        ok("Microsoft account authenticated")
        threading.Thread(target=pump, daemon=True).start()

    def stop(self):
        if self.running():
            self.proc.terminate()
            try:
                self.proc.wait(5)
            except subprocess.TimeoutExpired:
                self.proc.kill()
        _pkill("ProxyPass.jar")


def proton_env():
    env = dict(os.environ)
    env.update({"GAMEID": "0", "PROTONPATH": str(proton_path()),
                "PROTON_VERB": "run", "WINEPREFIX": str(PREFIX),
                "STEAM_COMPAT_CLIENT_INSTALL_PATH": str(HOME / ".steam/steam"),
                "UMU_RUNTIME_UPDATE": "0"})
    (HOME / ".steam/steam").mkdir(parents=True, exist_ok=True)
    return env


def umu(args, **kw):
    return run([sys.executable, str(ensure_umu())] + args,
               env=proton_env(), **kw)


def fix_curl_ssl(game_dir: Path):
    if (game_dir / "XCurl.dll.bol-orig").exists():
        return
    info("Installing libcurl + CA certificates …")
    pkg = CACHE / "mingw-curl.pkg.tar.zst"
    if not pkg.exists():
        download(MINGW_CURL, pkg, "libcurl")
    ex = CACHE / "mingw-curl"
    ex.mkdir(exist_ok=True)
    try:
        run(["tar", "--use-compress-program=unzstd", "-xf", str(pkg),
             "-C", str(ex)], capture_output=True)
    except Exception:
        run(["tar", "-xf", str(pkg), "-C", str(ex)])
    libcurl = next(ex.rglob("libcurl-4.dll"))
    if (game_dir / "XCurl.dll").exists():
        shutil.copy2(game_dir / "XCurl.dll", game_dir / "XCurl.dll.bol-orig")
    for nm in ("XCurl.dll", "Xcurl.dll"):
        shutil.copy2(libcurl, game_dir / nm)
    certs = PREFIX / "etc/ssl/certs"
    certs.mkdir(parents=True, exist_ok=True)
    if not (certs / "ca-bundle.crt").exists():
        download(CACERT_URL, certs / "ca-bundle.crt", "CA bundle")
    ok("libcurl + SSL ready")


def setup_prefix(game_dir: Path):
    PREFIX.mkdir(parents=True, exist_ok=True)
    s = load_settings()
    if s.get("prefix_ready"):
        return
    info("Initialising Wine prefix (first time) …")
    umu(["wineboot", "--init"], capture_output=True)
    msi = game_dir / "Installers/GameInputRedist.msi"
    if msi.exists():
        info("Installing GameInput redistributable …")
        try:
            umu(["msiexec", "/i", str(msi), "/qn"], capture_output=True)
        except subprocess.CalledProcessError:
            warn("GameInputRedist.msi non-zero (often harmless).")
    s["prefix_ready"] = True
    save_settings(s)
    ok("Wine prefix ready")


def kill_wine():
    """Kill leftover wine/wineserver for our Proton (a hard-killed hung run
    locks the prefix → next launch: 'no driver could be loaded')."""
    for pat in ("wineserver", "winedevice.exe", "GDK-Proton",
                "Minecraft.Windows.exe", "umu_run.py", "umu-shim",
                "pv-adverb"):
        _pkill(pat)


def reset_prefix():
    """Repair a corrupted Wine prefix (rebuilt on next launch)."""
    kill_wine()
    time.sleep(1)
    if PREFIX.exists():
        shutil.rmtree(PREFIX, ignore_errors=True)
    s = load_settings()
    s["prefix_ready"] = False
    save_settings(s)
    ok("Wine prefix reset — it will be rebuilt cleanly on next launch.")


OPTIONS_REL = ("drive_c/users/steamuser/AppData/Roaming/Minecraft Bedrock/"
               "Users/Shared/games/com.mojang/minecraftpe/options.txt")


def patch_options():
    opt = PREFIX / OPTIONS_REL
    if not opt.exists():
        return
    kv, order = {}, []
    for l in opt.read_text(errors="ignore").splitlines():
        if ":" in l:
            k, _, v = l.partition(":")
            k = k.strip()
            if k not in kv:
                order.append(k)
            kv[k] = v.strip()
    if kv.get("do_not_show_multiplayer_online_safety_warning") == "1":
        return
    if "do_not_show_multiplayer_online_safety_warning" not in order:
        order.append("do_not_show_multiplayer_online_safety_warning")
    kv["do_not_show_multiplayer_online_safety_warning"] = "1"
    opt.write_text("\n".join(f"{k}:{kv[k]}" for k in order) + "\n")
    ok("options.txt: multiplayer warning disabled")



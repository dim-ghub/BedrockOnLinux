    def refresh_mc():
        try:
            versions["mc"] = list_mc_versions(beta_var.get())
            vals = [v["tag"] + ("  · beta" if v["beta"] else "")
                    for v in versions["mc"]]

            def ap():
                mc_cb.configure(values=vals)
                if vals and not mc_var.get():
                    cur = (load_settings().get("mc_version") or "")
                    pick = next((v for v in vals if v.split("  ")[0] == cur
                                 or v.split("  ")[0].startswith(cur + ".")),
                                vals[0])
                    mc_var.set(pick)
            root.after(0, ap)
        except Exception as e:
            _LOG_SINK(f"xx versions MC: {e}")

    def refresh_engine():
        versions["proton"] = list_proton_tags() or ["latest"]
        versions["pp"] = ["auto"] + list_proxypass_tags()

        def ap():
            proton_cb.configure(values=versions["proton"])
            proton_var.set(versions["proton"][0])
            pp_cb.configure(values=versions["pp"])
            pp_var.set("auto")
        root.after(0, ap)

    threading.Thread(target=refresh_mc, daemon=True).start()
    threading.Thread(target=refresh_engine, daemon=True).start()

    def collect():
        st = load_settings()
        st["server"] = {"host": host_var.get().strip() or "play.linesia.net",
                        "port": int(port_var.get() or 19132)}
        st["native_login"] = bool(native_var.get())
        save_settings(st)
        mc = None
        if not own.get() and mc_var.get() and versions["mc"]:
            labels = [v["tag"] + ("  · beta" if v["beta"] else "")
                      for v in versions["mc"]]
            mc = versions["mc"][labels.index(mc_var.get())]
        pt = None if proton_var.get() in ("", "latest") else proton_var.get()
        ppt = None if pp_var.get() in ("", "auto") else pp_var.get()
        return mc, pt, ppt

    def busy(on):
        for b in (btn_setup, btn_play):
            b.configure(state="disabled" if on else "normal")

    def act(kind):
        busy(True)

        def work():
            try:
                mc, pt, ppt = collect()
                # 'Install / Update' forces a real refresh; PLAY stays fast
                do_setup(game_dir=own.get() or None, mc_ver=mc,
                         proton_tag=pt, pp_tag=ppt,
                         force=(kind == "setup"), progress=set_progress)
                if kind == "play":
                    launch(pp)
                else:
                    _LOG_SINK("OK Ready — click PLAY")
            except Exception as e:
                _LOG_SINK(f"xx {e}")
            finally:
                root.after(0, lambda: busy(False))
        threading.Thread(target=work, daemon=True).start()

    def on_close():
        pp.stop()
        na.stop()
        root.destroy()
    root.protocol("WM_DELETE_WINDOW", on_close)
    root.mainloop()


def main():
    p = argparse.ArgumentParser(prog=APP, description=f"{PRETTY} {VERSION}")
    sub = p.add_subparsers(dest="cmd")

    sp = sub.add_parser("setup", help="download & prepare everything")
    sp.add_argument("--game-dir", help="folder with Minecraft.Windows.exe")
    sp.add_argument("--mc", help="Minecraft version tag from the archive "
                                 "(e.g. 1.26.21.1)")
    sp.add_argument("--beta", action="store_true", help="allow beta versions")
    sp.add_argument("--proton", help="GDK-Proton tag (default: latest)")
    sp.add_argument("--proxypass", help="ProxyPass tag (default: auto)")
    sp.add_argument("--force", action="store_true")

    sub.add_parser("play", help="launch the game + ProxyPass")
    lv = sub.add_parser("versions", help="list available Minecraft versions")
    lv.add_argument("--beta", action="store_true")
    cf = sub.add_parser("config", help="show/set settings")
    cf.add_argument("--server", help="destination server  host:port")
    cf.add_argument("--native-login", choices=["on", "off"],
                    help="in-game Microsoft login (no ProxyPass, experimental)")
    sub.add_parser("login", help="link a Microsoft account (in-game login mode)")
    sub.add_parser("doctor", help="check host requirements")
    sub.add_parser("repair", help="reset a broken Wine prefix")
    sub.add_parser("gui", help="graphical launcher")

    a = p.parse_args()
    try:
        if a.cmd == "setup":
            mc = None
            if a.mc:
                vs = list_mc_versions(True)
                mc = next((v for v in vs if v["tag"] == a.mc), None)
                if not mc:
                    die(f"Minecraft version '{a.mc}' not found.")
            do_setup(a.game_dir, mc, a.proton, a.proxypass, a.force)
            ok(f"Done. Run:  {APP} play")
        elif a.cmd == "play":
            launch()
        elif a.cmd == "versions":
            for v in list_mc_versions(a.beta):
                print(f"  {v['tag']:<14}{'beta' if v['beta'] else 'stable':>7}"
                      f"   {v['size']>>20} MiB")
        elif a.cmd == "config":
            st = load_settings()
            srv = st.setdefault("server",
                                {"host": "play.linesia.net", "port": 19132})
            touched = False
            if a.server:
                h, _, pt = a.server.partition(":")
                srv.update(host=h, port=int(pt or 19132))
                save_settings(st)
                proxypass_config(srv["host"], srv["port"])
                ok(f"Server = {srv['host']}:{srv['port']}")
                touched = True
            if a.native_login:
                st["native_login"] = (a.native_login == "on")
                save_settings(st)
                ok(f"In-game login (no ProxyPass) = {a.native_login}")
                touched = True
            if not touched:
                print(json.dumps(st, indent=2))
        elif a.cmd == "login":
            if not load_settings().get("native_login"):
                die("Enable it first:  "
                    f"{APP} config --native-login on")
            na = NativeAuth()
            if na.signed_in():
                ok("A Microsoft account is already linked.")
            else:
                na._flow(None, None)
                if not na.signed_in():
                    sys.exit(1)
        elif a.cmd == "doctor":
            sys.exit(0 if doctor() else 1)
        elif a.cmd == "repair":
            reset_prefix()
        elif a.cmd == "gui":
            gui()
        else:
            if os.environ.get("DISPLAY") or os.environ.get("WAYLAND_DISPLAY"):
                gui()
            else:
                p.print_help()
    except BolError:
        sys.exit(1)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print()
        sys.exit(130)

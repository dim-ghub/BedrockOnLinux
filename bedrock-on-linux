def load_settings():
    s = {}
    if SETTINGS.exists():
        try:
            s = json.loads(SETTINGS.read_text())
        except Exception:
            s = {}
    # This branch is in-game login only (no ProxyPass): always build/use
    # the WineGDK fork unless the user pointed at another custom build.

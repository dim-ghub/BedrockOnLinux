def _vt(v):
    try:
        return tuple(int(x) for x in v.split("."))
    except Exception:
        return (0,)


def list_proxypass_tags():
    try:
        return [r["tag_name"] for r in gh_releases(PROXYPASS_REPO, 50)]
    except Exception:
        return []


def pick_proxypass(game_dir):
    ver = mc_version_str(game_dir)
    rels = gh_releases(PROXYPASS_REPO, 50)
    pres = [(m.group(1), r) for r in rels
            for m in [re.match(r"pre/(\d+\.\d+\.\d+)-\d+$", r["tag_name"])] if m]
    chosen = None
    if ver and pres:
        ex = [r for v, r in pres if v == ver]
        le = sorted([(v, r) for v, r in pres if _vt(v) <= _vt(ver)],
                    key=lambda x: _vt(x[0]))
        chosen = ex[0] if ex else (le[-1][1] if le else None)
    if not chosen:
        chosen = next((r for r in rels if r["tag_name"].startswith("master-")),
                      rels[0])
    return chosen, ver


def ensure_proxypass(game_dir, tag=None, force=False, progress=None):
    jar = PROXY_DIR / "ProxyPass.jar"
    s = load_settings()
    if jar.exists() and not force and s.get("proxypass_tag") and \
            (not tag or s.get("proxypass_tag") == tag):
        return jar
    if tag:
        rel = next((r for r in gh_releases(PROXYPASS_REPO, 50)
                    if r["tag_name"] == tag), None)
        ver = mc_version_str(game_dir)
    else:
        rel, ver = pick_proxypass(game_dir)
    if not rel:
        die(f"ProxyPass '{tag}' not found")
    url, _, _ = asset_url(rel, lambda n: n == "ProxyPass.jar")
    if not url:
        die("ProxyPass.jar asset missing.")
    PROXY_DIR.mkdir(parents=True, exist_ok=True)
    info(f"Downloading ProxyPass {rel['tag_name']} …")
    download(url, jar, f"ProxyPass {rel['tag_name']}", progress)
    s["proxypass_tag"] = rel["tag_name"]
    s["mc_version"] = ver
    save_settings(s)
    ok(f"ProxyPass {rel['tag_name']} (MC {ver or '?'}) ready")
    return jar


